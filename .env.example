# Yale Research Match — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Port for the Flask server (Railway sets this automatically)
PORT=5000

# Secret token for protected admin endpoints (moderation, availability writes)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=change-me-before-deploying

# Optional: set to "production" to disable Flask debug mode
FLASK_ENV=development
